<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.novel.mapper.NovelProjectMapper">

    <resultMap type="NovelProject" id="NovelProjectResult">
        <result property="projectId"      column="project_id"      />
        <result property="projectUuid"      column="project_uuid"      />
        <result property="title"          column="title"             />
        <result property="genre"          column="genre"             />
        <result property="status"         column="status"            />
        <result property="wordCount"      column="word_count"        />
        <result property="chapterCount"   column="chapter_count"     />
        <result property="coverUrl"       column="cover_url"         />
        <result property="summary"        column="summary"           />
        <result property="styleGuide"     column="style_guide"       />
        <result property="delFlag"        column="del_flag"          />
        <result property="createBy"       column="create_by"         />
        <result property="createTime"     column="create_time"       />
        <result property="updateBy"       column="update_by"         />
        <result property="updateTime"     column="update_time"       />
        <result property="remark"         column="remark"            />
    </resultMap>

    <sql id="selectNovelProjectVo">
        select project_id, project_uuid, title, genre, status, word_count, chapter_count,
               cover_url, summary, style_guide, del_flag, create_by, create_time, update_by, update_time, remark
        from novel_project
    </sql>

    <select id="selectNovelProjectByProjectId" parameterType="Long" resultMap="NovelProjectResult">
        <include refid="selectNovelProjectVo"/>
        where project_id = #{projectId} and del_flag = '0'
    </select>

    <select id="selectNovelProjectByUuid" parameterType="String" resultMap="NovelProjectResult">
        <include refid="selectNovelProjectVo"/>
        where project_uuid = #{projectUuid} and del_flag = '0'
    </select>

    <select id="selectNovelProjectList" parameterType="NovelProject" resultMap="NovelProjectResult">
        <include refid="selectNovelProjectVo"/>
        <where>
            del_flag = '0'
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="genre != null and genre != ''">
                AND genre = #{genre}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="createBy != null and createBy != ''">
                AND create_by = #{createBy}
            </if>
        </where>
        order by update_time desc, project_id desc
    </select>

    <insert id="insertNovelProject" parameterType="NovelProject" useGeneratedKeys="true" keyProperty="projectId">
        insert into novel_project (
            <if test="projectUuid != null and projectUuid != ''">project_uuid,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="genre != null and genre != ''">genre,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="wordCount != null">word_count,</if>
            <if test="chapterCount != null">chapter_count,</if>
            <if test="coverUrl != null and coverUrl != ''">cover_url,</if>
            <if test="summary != null">summary,</if>
            <if test="styleGuide != null">style_guide,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        ) values (
            <if test="projectUuid != null and projectUuid != ''">#{projectUuid},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="genre != null and genre != ''">#{genre},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="wordCount != null">#{wordCount},</if>
            <if test="chapterCount != null">#{chapterCount},</if>
            <if test="coverUrl != null and coverUrl != ''">#{coverUrl},</if>
            <if test="summary != null">#{summary},</if>
            <if test="styleGuide != null">#{styleGuide},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateNovelProject" parameterType="NovelProject">
        update novel_project
        <set>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="genre != null">genre = #{genre},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="wordCount != null">word_count = #{wordCount},</if>
            <if test="chapterCount != null">chapter_count = #{chapterCount},</if>
            <if test="coverUrl != null">cover_url = #{coverUrl},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="styleGuide != null">style_guide = #{styleGuide},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where project_id = #{projectId}
    </update>

    <update id="deleteNovelProjectByProjectId" parameterType="Long">
        update novel_project set del_flag = '2' where project_id = #{projectId}
    </update>

    <update id="deleteNovelProjectByProjectIds" parameterType="Long">
        update novel_project set del_flag = '2' where project_id in
        <foreach collection="array" item="projectId" open="(" separator="," close=")">
            #{projectId}
        </foreach>
    </update>

</mapper>
