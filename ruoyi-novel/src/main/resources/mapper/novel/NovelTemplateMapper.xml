<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.novel.mapper.NovelTemplateMapper">

    <resultMap type="NovelTemplate" id="NovelTemplateResult">
        <result property="templateId" column="template_id" />
        <result property="templateCode" column="template_code" />
        <result property="templateName" column="template_name" />
        <result property="templateType" column="template_type" />
        <result property="content" column="content" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
    </resultMap>

    <select id="selectNovelTemplateByCode" parameterType="String" resultMap="NovelTemplateResult">
        select template_id, template_code, template_name, template_type, content, status, remark
        from novel_template
        where template_code = #{templateCode} and status = '0'
    </select>

</mapper>